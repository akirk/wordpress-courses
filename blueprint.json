{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Learn WordPress",
		"description": "A personal study helper for Learn WordPress courses with course plans, lesson checklists, dates, and progress tracking.",
		"author": "Alex Kirk",
		"categories": [
			"Apps",
			"Education"
		]
	},
	"landingPage": "/learn-app/",
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/akirk/learn-app",
				"ref": "dist/main",
				"refType": "branch"
			},
			"options": {
				"activate": true,
				"targetFolderName": "learn-app"
			}
		}
	]
}
